# ---------------------------------------------------------------------------
# PostgreSQL (metadata – single source of truth)
# ---------------------------------------------------------------------------
POSTGRES_USER=qsearch
POSTGRES_PASSWORD=qsearch
POSTGRES_DB=qsearch
POSTGRES_HOST=localhost
# Host port for the Postgres container (5432 is already in use on this host)
POSTGRES_PORT=5433

# ---------------------------------------------------------------------------
# Qdrant (vector store)
# ---------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=documents

# ---------------------------------------------------------------------------
# Embedding model (local, multilingual)
# ---------------------------------------------------------------------------
EMBEDDING_MODEL=intfloat/multilingual-e5-large
# Vector dimension of the model (multilingual-e5-large = 1024)
VECTOR_SIZE=1024

# ---------------------------------------------------------------------------
# Chunking
# ---------------------------------------------------------------------------
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ---------------------------------------------------------------------------
# Search
# ---------------------------------------------------------------------------
# Oversampling factor for rescoring the quantized vectors
SEARCH_OVERSAMPLING=2.0

# ---------------------------------------------------------------------------
# Flask API
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=5001
