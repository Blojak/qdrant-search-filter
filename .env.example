# ---------------------------------------------------------------------------
# PostgreSQL (Metadaten – Single Source of Truth)
# ---------------------------------------------------------------------------
POSTGRES_USER=qsearch
POSTGRES_PASSWORD=qsearch
POSTGRES_DB=qsearch
POSTGRES_HOST=localhost
# Host-Port fuer den Postgres-Container (5432 ist auf diesem Host bereits belegt)
POSTGRES_PORT=5433

# ---------------------------------------------------------------------------
# Qdrant (Vektorspeicher)
# ---------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=documents

# ---------------------------------------------------------------------------
# Embedding-Modell (lokal, mehrsprachig)
# ---------------------------------------------------------------------------
EMBEDDING_MODEL=intfloat/multilingual-e5-large
# Vektordimension des Modells (multilingual-e5-large = 1024)
VECTOR_SIZE=1024

# ---------------------------------------------------------------------------
# Chunking
# ---------------------------------------------------------------------------
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ---------------------------------------------------------------------------
# Suche
# ---------------------------------------------------------------------------
# Oversampling-Faktor fuer das Rescoring der quantisierten Vektoren
SEARCH_OVERSAMPLING=2.0

# ---------------------------------------------------------------------------
# Flask-API
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=5001
